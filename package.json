{
  "name": "date-lookup-app",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "mvn -f backend/pom.xml spring-boot:run",
    "dev:frontend": "npm run dev -w frontend",
    "build": "mvn -f backend/pom.xml package && npm run build -w frontend",
    "test": "mvn -f backend/pom.xml test && npm run test -w frontend",
    "lint": "npm run lint -w frontend"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "playwright": "^1.60.0"
  }
}
